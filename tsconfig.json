{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@jackwener/opencli": ["src/main.ts"],
      "@jackwener/opencli/registry": ["src/registry-api.ts"],
      "@jackwener/opencli/errors": ["src/errors-api.ts"],
      "@jackwener/opencli/types": ["src/types.ts"],
      "@jackwener/opencli/utils": ["src/utils.ts"],
      "@jackwener/opencli/logger": ["src/logger.ts"],
      "@jackwener/opencli/launcher": ["src/launcher.ts"],
      "@jackwener/opencli/browser": ["src/browser-api.ts"],
      "@jackwener/opencli/browser/*": ["src/browser/*.ts"],
      "@jackwener/opencli/download": ["src/download/index.ts"],
      "@jackwener/opencli/download/*": ["src/download/*.ts"],
      "@jackwener/opencli/pipeline": ["src/pipeline/index.ts"],
      "@jackwener/opencli/pipeline/*": ["src/pipeline/*.ts"]
    },
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "incremental": true
  },
  "include": [
    "src/**/*.ts",
    "clis/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "extension"]
}
